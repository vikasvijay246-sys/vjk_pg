# ════════════════════════════════════════════════════════════════
#  .env.example — Copy to .env for local development
#  On Render, set these in the dashboard Environment tab.
# ════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars
JWT_SECRET_KEY=change-this-to-a-different-long-random-string
DATABASE_URL=postgresql://user:password@host:5432/pg_manager

# ── SocketIO (MUST match gunicorn worker class) ───────────────────
SOCKETIO_ASYNC_MODE=gevent     # gevent for Render, threading for local dev

# ── Render auto-sets this (used for upload path detection) ───────
RENDER=true

# ── Optional: Persistent file storage ────────────────────────────
# Add a Render Disk, mount it at /var/data, then set:
# RENDER_DISK_PATH=/var/data
# Without this, uploads go to /tmp (cleared on restart)

# ── Optional: AWS S3 for media ────────────────────────────────────
# S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=ap-south-1

# ── Optional: Firebase FCM push notifications ─────────────────────
# FIREBASE_CREDENTIALS_PATH=/etc/secrets/firebase.json

# ── Optional: Twilio SMS for OTP ──────────────────────────────────
# SMS_PROVIDER=twilio
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH=your_auth_token
# TWILIO_FROM=+1415xxxxxxx
